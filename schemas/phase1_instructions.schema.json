{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase 1 LLM instructions",
  "type": "object",
  "additionalProperties": false,
  "required": ["roles"],
  "properties": {
    "create_styles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["styleId", "derive_from_paragraph_index"],
        "properties": {
          "styleId": { "$ref": "#/$defs/reservedStyleId" },
          "name": {"type": "string"},
          "type": {"const": "paragraph"},
          "derive_from_paragraph_index": {"type": "integer", "minimum": 0},
          "basedOn": {"type": ["string", "null"]},
          "role": {"type": "string"}
        }
      }
    },
    "apply_pStyle": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["paragraph_index", "styleId"],
        "properties": {
          "paragraph_index": {"type": "integer", "minimum": 0},
          "styleId": {"type": "string", "minLength": 1}
        }
      }
    },
    "roles": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "SectionID": {"$ref": "#/$defs/roleSpec"},
        "SectionTitle": {"$ref": "#/$defs/roleSpec"},
        "PART": {"$ref": "#/$defs/roleSpec"},
        "ARTICLE": {"$ref": "#/$defs/roleSpec"},
        "PARAGRAPH": {"$ref": "#/$defs/roleSpec"},
        "SUBPARAGRAPH": {"$ref": "#/$defs/roleSpec"},
        "SUBSUBPARAGRAPH": {"$ref": "#/$defs/roleSpec"},
        "SUBPARAGRAPH_LEVEL_5": {"$ref": "#/$defs/roleSpec"},
        "SUBPARAGRAPH_LEVEL_6": {"$ref": "#/$defs/roleSpec"},
        "SUBPARAGRAPH_LEVEL_7": {"$ref": "#/$defs/roleSpec"},
        "SUBPARAGRAPH_LEVEL_8": {"$ref": "#/$defs/roleSpec"},
        "END_OF_SECTION": {"$ref": "#/$defs/roleSpec"}
      }
    },
    "ignored_paragraphs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["paragraph_index", "reason"],
        "properties": {
          "paragraph_index": {"type": "integer", "minimum": 0},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "reservedStyleId": {
      "type": "string",
      "enum": [
        "CSI_SectionTitle__ARCH",
        "CSI_SectionID__ARCH",
        "CSI_Part__ARCH",
        "CSI_Article__ARCH",
        "CSI_Paragraph__ARCH",
        "CSI_Subparagraph__ARCH",
        "CSI_Subsubparagraph__ARCH",
        "CSI_SubparagraphLevel5__ARCH",
        "CSI_SubparagraphLevel6__ARCH",
        "CSI_SubparagraphLevel7__ARCH",
        "CSI_SubparagraphLevel8__ARCH",
        "CSI_EndOfSection__ARCH"
      ]
    },
    "roleSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["styleId", "exemplar_paragraph_index"],
      "properties": {
        "styleId": {"type": "string", "minLength": 1},
        "exemplar_paragraph_index": {"type": "integer", "minimum": 0},
        "style_name": {"type": ["string", "null"]}
      }
    }
  }
}
